# Smart Rural AI Advisor - Environment Variables
# Copy to .env and fill real values. Do not commit .env.
# Scope: local development and deployment scripts only.
# Production Lambda runtime variables are defined in infrastructure/template.yaml.

# Core
AWS_REGION=ap-south-1

# Weather (prefer secret ARN in deployment)
OPENWEATHER_API_KEY=CHANGE_ME
OPENWEATHER_API_KEY_SECRET_ARN=

# Bedrock / KB
BEDROCK_KB_ID=
FOUNDATION_MODEL=apac.amazon.nova-pro-v1:0
FOUNDATION_MODEL_LITE=global.amazon.nova-2-lite-v1:0

# Cognito
COGNITO_USER_POOL_ID=YOUR_COGNITO_USER_POOL_ID

# DynamoDB table names (must match infrastructure/template.yaml)
DYNAMODB_PROFILES_TABLE=farmer_profiles
DYNAMODB_SESSIONS_TABLE=chat_sessions
DYNAMODB_RATE_LIMIT_TABLE=rate_limits

# Frontend runtime (Vite)
VITE_API_URL=https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/Prod
VITE_COGNITO_USER_POOL_ID=YOUR_COGNITO_USER_POOL_ID
VITE_COGNITO_CLIENT_ID=YOUR_COGNITO_CLIENT_ID
VITE_MOCK_AI=false
