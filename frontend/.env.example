# Frontend environment variables
# Copy to .env and fill in your values
# Scope: local frontend runtime only.
# Backend/Lambda production runtime variables are managed via infrastructure/template.yaml.

VITE_API_URL=https://YOUR_API_GATEWAY_URL/Prod
VITE_COGNITO_USER_POOL_ID=YOUR_COGNITO_USER_POOL_ID
VITE_COGNITO_CLIENT_ID=YOUR_COGNITO_CLIENT_ID
VITE_MOCK_AI=false
